# Supabase credentials for local development.
# Copy this file to ".env.local" and fill in the values from your Supabase
# project (Dashboard → Project Settings → API).
#
# IMPORTANT: only the PUBLIC anon key belongs here. Never put the secret
# service-role key in the frontend or commit it anywhere.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Corporate-customer details for the "Quartierbestätigung" form. These are real
# third-party details, so they are kept out of the source and injected at build
# time (set them as CI secrets for deployment). All optional — sensible
# placeholders are used when unset.
VITE_EUROWORK_COMPANY_NAME=Musterfirma GmbH
VITE_EUROWORK_COMPANY_ADDRESS=Musterstraße 1, 0000 Musterstadt
VITE_EUROWORK_COMPANY_PHONE=0000/000000
VITE_EUROWORK_COMPANY_EMAIL=office@example.com
VITE_EUROWORK_COMPANY_BETREUER=Hr. Mustermann
VITE_EUROWORK_FOOTER_COMPANY=Firma Musterfirma GmbH
